# ─────────────────────────────────────────────────────────────
# Vijaya Dental Admin Panel — Apache Security Rules
# ─────────────────────────────────────────────────────────────

# ── Disable directory listing ────────────────────────────────
Options -Indexes

# ── Block direct access to includes/ ────────────────────────
<FilesMatch "\.(php)$">
    # Allow PHP files everywhere by default
    Require all granted
</FilesMatch>

# Deny access to includes directory files directly
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to includes/*.php
    RewriteRule ^includes/ - [F,L]

    # Enforce trailing slash isn't needed for panel

    # Redirect HTTP → HTTPS (uncomment for production)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Protect sensitive files ───────────────────────────────────
<FilesMatch "(\.env|\.git|\.htpasswd|database\.sql|composer\.json)$">
    Require all denied
</FilesMatch>

# ── Security headers ─────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Cache static assets ──────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css         "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png        "access plus 1 month"
    ExpiresByType image/jpeg       "access plus 1 month"
    ExpiresByType image/webp       "access plus 1 month"
</IfModule>
